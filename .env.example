# ============================================================
# Polymarket Weather Trading Bot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Trading Mode ---
# Options: backtest, paper, live
TRADING_MODE=paper
ENABLE_POLYMARKET=true
ENABLE_KALSHI=true

# --- Slack Alerts ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/XXXX/XXXX

# --- Polymarket (only needed for LIVE trading) ---
# Export from: Polymarket.com → Cash → ⋯ → Export Private Key
POLYMARKET_PRIVATE_KEY=0x...
# Your proxy/funder wallet address from polymarket.com/settings
POLYMARKET_FUNDER_ADDRESS=0x...

# --- Kalshi (needed for LIVE trading later; public market data works without keys) ---
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/kalshi-api-key.key
KALSHI_USE_DEMO=true
KALSHI_ENV=demo
KALSHI_LIVE_ENABLED=false
# KALSHI_LIVE_BANKROLL_SLICE_USD=250
# KALSHI_LIVE_MAX_TRADE_SIZE_USD=10
# KALSHI_LIVE_MAX_DAILY_LOSS_USD=25
# KALSHI_LIVE_MAX_OPEN_EXPOSURE_USD=75
# KALSHI_LIVE_MIN_CASH_BUFFER_USD=100
# KALSHI_LIVE_MAX_POSITIONS=10
# KALSHI_LIVE_CONTRARIAN_MAX_TRADE_SIZE_USD=5
# KALSHI_LIVE_ALLOWED_DRIFT_CENTS=2
# KALSHI_LIVE_ORDER_SLIPPAGE_CENTS=2
# KALSHI_LIVE_SETTLEMENT_BUFFER_MINUTES=60

# --- Strategy Parameters (optional overrides) ---
# EDGE_THRESHOLD=0.08
# KELLY_FRACTION=0.15
# MAX_TRADE_SIZE=50
# MAX_DAILY_LOSS=200
# SCAN_INTERVAL_SECONDS=300
# KALSHI_FEE_BUFFER_PCT=0.00
# KALSHI_NWS_BLEND_WEIGHT=0.65
# KALSHI_NWS_DISAGREEMENT_THRESHOLD_F=3.0
# KALSHI_MAX_FORECAST_LEAD_HOURS=24
# POLYMARKET_PAPER_BANKROLL=1000
# KALSHI_PAPER_BANKROLL=1000
