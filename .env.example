# ============================================================
# Polymarket Weather Trading Bot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Trading Mode ---
# Options: backtest, paper, live
TRADING_MODE=paper

# --- Slack Alerts ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/XXXX/XXXX

# --- Polymarket (only needed for LIVE trading) ---
# Export from: Polymarket.com → Cash → ⋯ → Export Private Key
POLYMARKET_PRIVATE_KEY=0x...
# Your proxy/funder wallet address from polymarket.com/settings
POLYMARKET_FUNDER_ADDRESS=0x...

# --- Strategy Parameters (optional overrides) ---
# EDGE_THRESHOLD=0.08
# KELLY_FRACTION=0.15
# MAX_TRADE_SIZE=50
# MAX_DAILY_LOSS=200
# SCAN_INTERVAL_SECONDS=300
