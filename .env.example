# ============================================================
# Polymarket Weather Trading Bot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Trading Mode ---
# Options: backtest, paper, live
TRADING_MODE=paper
ENABLE_POLYMARKET=true
ENABLE_KALSHI=true

# --- Slack Alerts ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/XXXX/XXXX

# --- Polymarket (only needed for LIVE trading) ---
# Export from: Polymarket.com → Cash → ⋯ → Export Private Key
POLYMARKET_PRIVATE_KEY=0x...
# Your proxy/funder wallet address from polymarket.com/settings
POLYMARKET_FUNDER_ADDRESS=0x...

# --- Kalshi (needed for LIVE trading later; public market data works without keys) ---
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/kalshi-api-key.key
KALSHI_USE_DEMO=true

# --- Strategy Parameters (optional overrides) ---
# EDGE_THRESHOLD=0.08
# KELLY_FRACTION=0.15
# MAX_TRADE_SIZE=50
# MAX_DAILY_LOSS=200
# SCAN_INTERVAL_SECONDS=300
# KALSHI_FEE_BUFFER_PCT=0.00
# POLYMARKET_PAPER_BANKROLL=1000
# KALSHI_PAPER_BANKROLL=1000
